pipeline {
    agent any
    stages('Build') {
    steps {
        sh 'sleep 5'
        echo " this is build stage "
    }
}
stages('Test') {
steps {
    sh 'sleep 5'
    echo " this is test stage "
}
}
stages('Deploy') {
    steps {
        sh 'sleep 5'
        echo " this is deploy stage "
    }
}
}
